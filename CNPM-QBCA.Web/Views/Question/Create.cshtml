@model QBCA.Models.Question
@using QBCA.Controllers
@{
    ViewBag.Title = "Add New Question";
    Layout = "~/Views/Shared/_LayoutHome.cshtml";

    string userName = (string)ViewBag.UserName ?? "User";
    string avatarInitials = !string.IsNullOrWhiteSpace(userName)
        ? userName.Trim().Substring(0, 1).ToUpper() : "U";

    ViewBag.AvatarInitials = avatarInitials;

    var duplicates   = ViewBag.DuplicateWarning as List<DuplicateHint>;
    bool hasDuplicate = duplicates != null && duplicates.Count > 0;
}

<section class="min-vh-100 d-flex align-items-start justify-content-center bg-light" style="padding-top: 100px;">
    <div class="neumorphic-box" style="max-width: 600px;">
        <h3 class="text-center fw-bold mb-4 text-dark">
            <span style="color:#6d82f3;"><i class="fas fa-plus"></i></span> Add New Question
        </h3>

        @* ── WARNING: Câu hỏi trùng lặp ── *@
        @if (hasDuplicate)
        {
            <div class="duplicate-warning-box mb-4">
                <div class="d-flex align-items-center mb-2">
                    <i class="fas fa-exclamation-triangle me-2" style="color:#e67e22; font-size:1.2rem;"></i>
                    <strong style="color:#c0392b; font-size:1.05rem;">Phát hiện câu hỏi tương tự!</strong>
                </div>
                <p class="mb-2" style="font-size:.95rem; color:#555;">Câu hỏi sau đây có nội dung gần giống với câu bạn đang nhập:</p>
                <ul class="list-unstyled mb-3">
                    @foreach (var d in duplicates!)
                    {
                        <li class="duplicate-item">
                            <span class="badge-score">@d.Score%</span>
                            <span class="duplicate-preview">@d.Preview</span>
                        </li>
                    }
                </ul>
                <p class="mb-0" style="font-size:.9rem; color:#888;">Bạn có thể chỉnh sửa lại nội dung hoặc nhấn <strong>"Lưu dù trùng"</strong> nếu muốn lưu.</p>
            </div>
        }

        @* ── WARNING: Jina API lỗi (nhẹ) ── *@
        @if (ViewBag.ApiWarning != null)
        {
            <div class="alert alert-warning py-2 px-3 mb-3" style="font-size:.9rem; border-radius:10px;">
                <i class="fas fa-wifi me-1"></i> @ViewBag.ApiWarning
            </div>
        }

        @using (Html.BeginForm("Create", "Question", FormMethod.Post, new { id = "question-form" }))
        {
            @Html.AntiForgeryToken()
            @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

            @* Hidden field forceCreate – mặc định false, sẽ được set true khi bấm "Lưu dù trùng" *@
            <input type="hidden" name="forceCreate" id="forceCreate" value="false" />

            <label class="neumorphic-label" for="Content">Question Content</label>
            @Html.TextAreaFor(m => m.Content, 4, 60, new { @class = "neumorphic-input", placeholder = "Enter question content here...", id = "Content" })
            @Html.ValidationMessageFor(m => m.Content, "", new { @class = "text-danger small" })

            <!-- SUBJECT -->
            <label class="neumorphic-label" for="SubjectID">Subject</label>
            @Html.DropDownListFor(
                m => m.SubjectID,
                ViewBag.Subjects != null
                ? new SelectList(ViewBag.Subjects, "SubjectID", "SubjectName", Model?.SubjectID)
                : new SelectList(Enumerable.Empty<object>(), "Value", "Text"),
                "Select Subject",
                new { @class = "neumorphic-select", id = "SubjectID" }
            )
            @Html.ValidationMessageFor(m => m.SubjectID, "", new { @class = "text-danger small" })

            <!-- CLO -->
            <label class="neumorphic-label" for="CLOID">CLO</label>
            @Html.DropDownListFor(
                m => m.CLOID,
                ViewBag.CLOs != null
                ? new SelectList(ViewBag.CLOs, "CLOID", "Description", Model?.CLOID)
                : new SelectList(Enumerable.Empty<object>(), "Value", "Text"),
                "Select CLO",
                new { @class = "neumorphic-select", id = "CLOID" }
            )
            @Html.ValidationMessageFor(m => m.CLOID, "", new { @class = "text-danger small" })

            <!-- DIFFICULTY LEVEL -->
            <label class="neumorphic-label" for="DifficultyLevelID">Difficulty Level</label>
            @Html.DropDownListFor(
                m => m.DifficultyLevelID,
                ViewBag.DifficultyLevels != null
                ? new SelectList(ViewBag.DifficultyLevels, "DifficultyLevelID", "LevelName", Model?.DifficultyLevelID)
                : new SelectList(Enumerable.Empty<object>(), "Value", "Text"),
                "Select Difficulty Level",
                new { @class = "neumorphic-select", id = "DifficultyLevelID" }
            )
            @Html.ValidationMessageFor(m => m.DifficultyLevelID, "", new { @class = "text-danger small" })

            <!-- STATUS -->
            <label class="neumorphic-label" for="Status">Status</label>
            @Html.DropDownListFor(
                m => m.Status,
                new SelectList(new[] { "Active", "Inactive" }, Model?.Status),
                "Select Status",
                new { @class = "neumorphic-select", id = "Status" }
            )
            @Html.ValidationMessageFor(m => m.Status, "", new { @class = "text-danger small" })

            <button type="submit" class="neumorphic-button">
                <i class="fas fa-save me-1"></i> Add Question
            </button>

            @if (hasDuplicate)
            {
                <button type="button" class="btn-force-create" onclick="submitForce()">
                    <i class="fas fa-exclamation-circle me-1"></i> Lưu dù trùng
                </button>
            }

            <a href="@Url.Action("Questions", "Question")" class="btn btn-link w-100 text-center" style="font-weight:500;">Cancel</a>
        }
    </div>
</section>

@section Styles {
    <style>
        .neumorphic-box {
            background: #f2f3f7;
            border-radius: 25px;
            box-shadow: 8px 8px 16px #d1d9e6, -8px -8px 16px #ffffff;
            padding: 40px;
            max-width: 560px;
            margin: auto;
        }

        .neumorphic-label {
            font-weight: 600;
            color: #36395A;
            margin-bottom: 7px;
            margin-left: 2px;
            display: block;
            letter-spacing: 0.02em;
        }

        .neumorphic-input, .neumorphic-select {
            border: none;
            outline: none;
            background: #f2f3f7;
            border-radius: 12px;
            padding: 14px 20px;
            box-shadow: inset 6px 6px 10px #d1d9e6, inset -6px -6px 10px #ffffff;
            width: 100%;
            box-sizing: border-box;
            font-size: 16px;
            margin-bottom: 22px;
        }

        .neumorphic-button {
            background-color: #4F46E5;
            color: white;
            padding: 12px 25px;
            font-weight: 600;
            border: none;
            border-radius: 12px;
            width: 100%;
            box-sizing: border-box;
            box-shadow: 3px 3px 8px rgba(0,0,0,0.1);
            transition: 0.2s;
            margin-top: 16px;
            margin-bottom: 8px;
            font-size: 1.13rem;
        }

        .neumorphic-button:hover { background-color: #3730A3; }

        .text-danger.small { font-size: .98em; margin-left: 3px; }

        /* ── Duplicate warning box ── */
        .duplicate-warning-box {
            background: #fff8f0;
            border: 2px solid #f0a500;
            border-radius: 14px;
            padding: 18px 20px;
            animation: fadeInSlide .4s ease;
        }
        @@keyframes fadeInSlide {
            from { opacity: 0; transform: translateY(-10px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        .duplicate-item {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            margin-bottom: 10px;
            padding: 10px 12px;
            background: #fff3e0;
            border-radius: 10px;
        }
        .badge-score {
            background: #e67e22;
            color: #fff;
            border-radius: 6px;
            padding: 2px 8px;
            font-size: .82rem;
            font-weight: 700;
            white-space: nowrap;
            min-width: 48px;
            text-align: center;
        }
        .duplicate-preview {
            font-size: .93rem;
            color: #444;
            line-height: 1.45;
        }
        .btn-force-create {
            background: linear-gradient(135deg, #e67e22, #c0392b);
            color: #fff;
            border: none;
            border-radius: 12px;
            width: 100%;
            padding: 11px;
            font-weight: 600;
            font-size: 1rem;
            margin-bottom: 8px;
            cursor: pointer;
            box-shadow: 3px 3px 8px rgba(0,0,0,0.15);
            transition: opacity .2s;
        }
        .btn-force-create:hover { opacity: .88; }
    </style>
}

@section Scripts {
    <script>
        function submitForce() {
            document.getElementById('forceCreate').value = 'true';
            document.getElementById('question-form').submit();
        }
    </script>
}

    </div>
</section>
