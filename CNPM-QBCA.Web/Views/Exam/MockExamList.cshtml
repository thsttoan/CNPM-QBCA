@model IEnumerable<QBCA.Models.Exam>
@{
    Layout = "~/Views/Shared/_LayoutHome.cshtml";
    ViewBag.Title = "Mock Exams";
}

<main style="padding:28px 32px;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
        <h2 style="font-size:1.5rem;font-weight:700;color:#36395a;">
            <i class="fas fa-file-signature" style="color:#27ae60;margin-right:8px;"></i>
            Mock Exam List
        </h2>
    </div>

    @if (TempData["Success"] != null)
    {
        <div style="background:#eafaf1;border:1px solid #2ecc71;border-radius:10px;padding:14px 20px;margin-bottom:18px;color:#1a7a42;font-weight:500;">
            <i class="fas fa-check-circle"></i> @TempData["Success"]
        </div>
    }

    <p style="color:#666;margin-bottom:18px;">
        These exams are available for mock review. Take an exam and submit your feedback to help improve it.
    </p>

    @if (!Model.Any())
    {
        <div style="text-align:center;padding:60px;color:#aaa;">
            <i class="fas fa-file-signature" style="font-size:3rem;margin-bottom:12px;display:block;"></i>
            No exams available for mock review yet.
        </div>
    }
    else
    {
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:18px;">
            @foreach (var exam in Model)
            {
                <div style="background:#fff;border:1.5px solid #e0e8ff;border-radius:14px;padding:22px;box-shadow:4px 4px 14px #c7d0e830;">
                    <div style="font-size:1.05rem;font-weight:700;color:#36395a;margin-bottom:6px;">
                        @exam.Title
                    </div>
                    <div style="color:#888;font-size:.9rem;margin-bottom:4px;">
                        <i class="fas fa-book" style="width:16px;"></i>
                        @(exam.ExamPlanDistribution?.ExamPlan?.Subject?.SubjectName ?? "N/A")
                    </div>
                    <div style="color:#888;font-size:.9rem;margin-bottom:4px;">
                        <i class="fas fa-calendar-alt" style="width:16px;"></i>
                        Submitted: @exam.SubmitDate.ToString("dd/MM/yyyy")
                    </div>
                    <div style="margin-bottom:14px;">
                        <span style="display:inline-block;padding:3px 12px;border-radius:20px;font-size:.82rem;font-weight:600;
                              background:@(exam.Status == "Approved" ? "#eafaf1" : "#fef9e7");
                              color:@(exam.Status == "Approved" ? "#1a7a42" : "#b7770d");">
                            @exam.Status
                        </span>
                    </div>
                    <a href="@Url.Action("MockExamDetails","Exam",new{id=exam.ExamID})"
                       style="display:inline-block;padding:8px 18px;background:#667eea;color:#fff;border-radius:8px;font-weight:600;text-decoration:none;font-size:.92rem;transition:background .2s;"
                       onmouseover="this.style.background='#4f5bb8'" onmouseout="this.style.background='#667eea'">
                        <i class="fas fa-play"></i> Take Mock Exam
                    </a>
                </div>
            }
        </div>
    }
</main>
