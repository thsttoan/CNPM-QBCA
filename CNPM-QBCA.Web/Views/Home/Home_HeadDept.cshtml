@{
    Layout = "~/Views/Shared/_LayoutHome.cshtml";
    ViewBag.Title = "Head of Department Dashboard";
    ViewBag.RoleName = "Head of Department";
}

<main class="dashboard-container">
    <div class="welcome-banner">
        <h1>Welcome, @(User.FindFirst("FullName")?.Value ?? "Head of Department")!</h1>
        <p style="color:#666;">Oversee question creation and task assignments</p>
    </div>

    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:20px;padding:20px 0;">
        <a href="@Url.Action("Plans","AssignedPlan")" class="dash-card" style="border-color:#f0a500;">
            <i class="fas fa-tasks" style="color:#f0a500;"></i>
            <span>Assigned Plans</span>
        </a>
        <a href="@Url.Action("Task","AssignTask")" class="dash-card">
            <i class="fas fa-user-plus"></i>
            <span>Assign Tasks</span>
        </a>
        <a href="@Url.Action("SubmissionApproval","SubmissionApproval")" class="dash-card" style="border-color:#27ae60;">
            <i class="fas fa-check-square" style="color:#27ae60;"></i>
            <span>Submission Approval</span>
        </a>
        <a href="@Url.Action("Notifications","Notifications")" class="dash-card">
            <i class="fas fa-bell"></i>
            <span>Notifications</span>
        </a>
    </div>
</main>

@section Styles {
<style>
.dash-card {
    display:flex;flex-direction:column;align-items:center;justify-content:center;
    gap:12px;padding:28px 16px;
    background:#f8faff;border:1.5px solid #e0e8ff;
    border-radius:16px;text-decoration:none;color:#36395a;
    font-weight:600;font-size:.97rem;
    box-shadow:4px 4px 12px #c7d0e840;
    transition:all .2s;
}
.dash-card:hover{transform:translateY(-3px);box-shadow:6px 8px 18px #b0c0e860;background:#fff;}
.dash-card i{font-size:2rem;color:#667eea;}
</style>
}