@using QBCA.ViewModels.ReviewExam
@model ReviewExamDetailViewModel

@{
    ViewBag.Title = "Review Exam Details";
    Layout = "~/Views/Shared/_LayoutHome.cshtml";
}

<div class="container py-4">
    <div class="main-content-area">
        <div class="card shadow p-4 rounded-4 bg-light">
            <h2 class="mb-4 text-primary">Review Exam Details</h2>

            <dl class="row">
                <dt class="col-sm-3">Exam Title:</dt>
                <dd class="col-sm-9">@Model.ExamTitle</dd>

                <dt class="col-sm-3">Lecturer:</dt>
                <dd class="col-sm-9">@Model.LecturerName</dd>

                <dt class="col-sm-3">Subject:</dt>
                <dd class="col-sm-9">@Model.SubjectName</dd>

                <dt class="col-sm-3">Status:</dt>
                <dd class="col-sm-9">
                    <span class="badge bg-@(Model.Status == "Approved" ? "success" : Model.Status == "Rejected" ? "danger" : "warning")">
                        @Model.Status
                    </span>
                </dd>

                <dt class="col-sm-3">Submitted Date:</dt>
                <dd class="col-sm-9">@Model.SubmittedDate.ToString("yyyy-MM-dd")</dd>

                <dt class="col-sm-3">Due Date:</dt>
                <dd class="col-sm-9">@Model.DueDate?.ToString("yyyy-MM-dd") ?? "N/A"</dd>

                <dt class="col-sm-3">Reviewed At:</dt>
                <dd class="col-sm-9">@Model.ReviewedAt.ToString("yyyy-MM-dd HH:mm")</dd>

                <dt class="col-sm-3">Comment:</dt>
                <dd class="col-sm-9">@Model.Comment</dd>
            </dl>
            
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success mt-3">@TempData["Success"]</div>
            }

            @if (User.FindFirst("RoleID")?.Value == "5" && Model.Status == "Submitted")
            {
                <div class="mt-4 border-top pt-3 d-flex gap-2">
                    <form asp-action="UpdateStatus" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.ReviewID" />
                        <input type="hidden" name="status" value="Approved" />
                        <button type="submit" class="btn btn-success"><i class="fas fa-check"></i> Approve Feedback</button>
                    </form>
                    <form asp-action="UpdateStatus" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.ReviewID" />
                        <input type="hidden" name="status" value="Rejected" />
                        <button type="submit" class="btn btn-danger"><i class="fas fa-times"></i> Reject Feedback</button>
                    </form>
                </div>
            }
            else
            {
                <div class="mt-4 border-top pt-3">
                    <a href="@Url.Action("ReviewExam", "ExamReview")" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Back to List
                    </a>
                </div>
            }
        </div>
    </div>
</div>
