@model IEnumerable<QBCA.ViewModels.SubmissionApprovalViewModel>
@{
    ViewBag.Title = "Submission Approvals";
    Layout = "~/Views/Shared/_LayoutHome.cshtml";
}

    <style>
        .main-content-area {
            margin-left: 34px;
            margin-right: 34px;
        }

        .table-container {
            background: #fff;
            border-radius: 14px;
            box-shadow: 0 1px 6px #0000000d;
            padding: 0.5rem 0.5rem 0.5rem 0.5rem;
            margin-bottom: 20px;
        }

        .subject-table {
            border-collapse: separate;
            border-spacing: 0;
            font-size: 1.17rem;
            min-width: 650px;
        }

            .subject-table thead tr th {
                background: #6277ea;
                color: #fff;
                border: none;
                font-weight: 700;
                font-size: 1.18rem;
                text-align: left;
                padding-left: 24px;
                padding-top: 15px;
                padding-bottom: 15px;
            }

                .subject-table thead tr th:first-child {
                    border-top-left-radius: 11px;
                }

                .subject-table thead tr th:last-child {
                    border-top-right-radius: 11px;
                }

            .subject-table tbody tr {
                background: #fafbfc;
                border-bottom: 1px solid #e6e7eb;
            }

                .subject-table tbody tr:last-child {
                    border-bottom-left-radius: 10px;
                    border-bottom-right-radius: 10px;
                }

            .subject-table td {
                vertical-align: middle;
                padding: 0.88rem 0.8rem 0.88rem 24px;
                font-size: 1.14rem;
            }

        .action-links a {
            margin: 0 4px;
            text-decoration: none;
            font-weight: 600;
            font-size: 1rem;
            color: #4F46E5;
        }

        .action-links a:hover {
            text-decoration: underline;
        }
    </style>

<div class="container py-4">
    <div class="main-content-area">
        <div style="margin-bottom: 18px;">
            <h2 class="fw-bold mb-2" style="font-size:2.1rem;">Submission Approvals</h2>
            <div class="text-secondary" style="font-size:1.18rem;">
                Review and approve exam submissions.
            </div>
        </div>

        <div class="table-container">
            <table class="table subject-table mb-0">
                <thead>
                    <tr>
                        <th style="width:5%;">#</th>
                        <th style="width:25%;">Submission</th>
                        <th style="width:20%;">Subject</th>
                        <th style="width:12%;">Status</th>
                        <th style="width:15%;">Approved By</th>
                        <th style="width:10%;">Date</th>
                        <th style="width:13%;">Actions</th>
                    </tr>
                </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                int index = 1;
                foreach (var item in Model)
                {
                    var statusLower = item.Status?.ToLower() ?? "pending";
                    <tr>
                        <td>@(index++)</td>
                        <td>@item.SubmissionTitle</td>
                        <td>@item.SubjectName</td>
                        <td>
                            @item.Status
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.ApprovedByName))
                            {
                                <span title="Approved on @item.ApprovedDate?.ToString("dd/MM/yyyy")">
                                    @item.ApprovedByName
                                </span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td>
                            @(item.ApprovedDate.HasValue? item.ApprovedDate.Value.ToString("dd/MM/yyyy") : "—")
                        </td>
                        <td class="action-links">
                            <a href="@Url.Action("Details", "SubmissionApproval", new { id = item.SubmissionApprovalID })"><i class="fas fa-eye"></i> View</a>
                            <a href="@Url.Action("Edit", "SubmissionApproval", new { id = item.SubmissionApprovalID })"><i class="fas fa-edit"></i> Edit</a>
                            <a href="@Url.Action("Delete", "SubmissionApproval", new { id = item.SubmissionApprovalID })" class="text-danger"><i class="fas fa-trash-alt"></i> Delete</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" class="text-center py-4 text-muted">
                        <i class="fas fa-file-alt fa-lg mb-2"></i><br />
                        <span style="font-size:1.11rem;">No submissions pending approval at the moment.</span>
                    </td>
                </tr>
            }
        </tbody>
        </table>
    </div>
</div>
