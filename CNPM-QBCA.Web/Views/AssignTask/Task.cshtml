@model IEnumerable<QBCA.ViewModels.AssignTaskViewModel>
@{
    ViewBag.Title = "Assigned Tasks";
    Layout = "~/Views/Shared/_LayoutHome.cshtml";
}

<style>
    .main-content-area {
        margin-left: 34px;
        margin-right: 34px;
    }

    .table-container {
        background: #fff;
        border-radius: 14px;
        box-shadow: 0 1px 6px #0000000d;
        padding: 0.5rem 0.5rem 0.5rem 0.5rem;
        margin-bottom: 20px;
    }

    .subject-table {
        border-collapse: separate;
        border-spacing: 0;
        font-size: 1.17rem;
        min-width: 650px;
    }

        .subject-table thead tr th {
            background: #6277ea;
            color: #fff;
            border: none;
            font-weight: 700;
            font-size: 1.18rem;
            text-align: left;
            padding-left: 24px;
            padding-top: 15px;
            padding-bottom: 15px;
        }

            .subject-table thead tr th:first-child {
                border-top-left-radius: 11px;
            }

            .subject-table thead tr th:last-child {
                border-top-right-radius: 11px;
            }

        .subject-table tbody tr {
            background: #fafbfc;
            border-bottom: 1px solid #e6e7eb;
        }

            .subject-table tbody tr:last-child {
                border-bottom-left-radius: 10px;
                border-bottom-right-radius: 10px;
            }

        .subject-table td {
            vertical-align: middle;
            padding: 0.88rem 0.8rem 0.88rem 24px;
            font-size: 1.14rem;
        }

    .action-links a {
        margin: 0 4px;
        text-decoration: none;
        font-weight: 600;
        font-size: 1rem;
        color: #4F46E5;
    }
    .action-links a:hover {
        text-decoration: underline;
    }
</style>

<div class="container py-4">
    <div class="main-content-area">
        <div style="margin-bottom: 18px;">
            <h2 class="fw-bold mb-2" style="font-size:2.1rem;">Assigned Tasks</h2>
            <div class="text-secondary" style="font-size:1.18rem;">
                Manage assignments given to lecturers.
                <div style="margin-top: 5px;">
                    <a href="@Url.Action("Create", "AssignTask")" style="color:#6277ea; font-weight:600; text-decoration:none;">
                        <i class="fas fa-plus"></i> New Task
                    </a>
                </div>
            </div>
        </div>

        <div style="margin-bottom: 18px;">
            <form method="get" asp-action="Task">
                <span class="text-secondary" style="font-size:1.18rem;">Filter by Lecturer</span>
                <select name="assignedTo" onchange="this.form.submit()" style="padding: 5px 10px; border-radius: 6px; border: 1px solid #ccc; font-size: 1rem; margin-left: 10px;">
                    <option value="">-- All Lecturers --</option>
                    @foreach (var name in ViewBag.AllLecturers as List<string>)
                    {
                        <option value="@name" selected="@(Context.Request.Query["assignedTo"] == name ? "selected" : null)">@name</option>
                    }
                </select>
            </form>
        </div>

        <div class="table-container">
            <table class="table subject-table mb-0">
                <thead>
                    <tr>
                        <th style="width:5%;">#</th>
                        <th style="width:25%;">Task Title</th>
                        <th style="width:20%;">Assigned To</th>
                        <th style="width:10%;">Status</th>
                        <th style="width:12%;">Deadline</th>
                        <th style="width:13%;">Assigned At</th>
                        <th style="width:15%;">Actions</th>
                    </tr>
                </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                int i = 1;
                foreach (var item in Model)
                {
                    <tr>
                        <td>@(i++)</td>
                        <td>@item.TaskType</td>
                        <td>@item.AssignedToName</td>
                        <td>
                            @item.Status
                        </td>
                        <td>@item.Deadline.ToString("dd/MM/yyyy")</td>
                        <td>@item.AssignedAt.ToString("dd/MM/yyyy")</td>
                        <td class="action-links">
                            <a href="@Url.Action("Edit", "AssignTask", new { id = item.TaskID })"><i class="fas fa-edit"></i> Edit</a>
                            <a href="@Url.Action("Details", "AssignTask", new { id = item.TaskID })"><i class="fas fa-eye"></i> Details</a>
                            <a href="@Url.Action("Delete", "AssignTask", new { id = item.TaskID })" class="text-danger"><i class="fas fa-trash-alt"></i> Delete</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" class="text-center py-4 text-muted">
                        <i class="fas fa-tasks fa-lg mb-2"></i><br />
                        <span style="font-size:1.11rem;">No tasks assigned.</span>
                    </td>
                </tr>
            }
        </tbody>
        </table>
    </div>
</div>
</div>
